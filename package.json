{
  "name": "craft-ui",
  "version": "0.1.0",
  "description": "Craft-themed React UI primitives — paper, rope, crayon palette",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/craft-ui.cjs",
  "module": "./dist/craft-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/craft-ui.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/craft-ui.cjs"
      }
    },
    "./styles.css": "./dist/craft-ui.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "CRAFTUI_BUILD_LIBRARY=true vite build",
    "lint": "eslint src .storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.13.0",
    "postcss": "^8.4.49",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0"
  },
  "keywords": [
    "react",
    "ui",
    "craft",
    "tailwind"
  ],
  "license": "MIT",
  "dependencies": {
    "roughjs": "^4.6.6"
  }
}
